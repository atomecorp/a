{
  "name": "thermal-vitest-framework",
  "version": "1.0.0",
  "description": "Complete Vitest testing framework for thermal application database",
  "dependencies": {
    "objection": "^3.1.3",
    "knex": "^3.1.0"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "vite": "^5.0.0",
    "@vitest/ui": "^1.0.0",
    "sqlite3": "^5.1.6"
  },
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:database": "vitest run tests/database.test.js",
    "test:integration": "vitest run tests/thermal-integration.test.js",
    "test:browser": "vitest --browser"
  },
  "keywords": [
    "thermal",
    "testing",
    "vitest",
    "vite",
    "objection",
    "database",
    "university",
    "fast-testing"
  ],
  "author": "Thermal App Team",
  "license": "MIT"
}
