{
  "name": "thermal-vitest-framework",
  "version": "1.0.0",
  "description": "Lightning-fast Vitest testing framework for thermal monitoring applications",
  "type": "module",
  "main": "index.js",  "scripts": {
    "test": "vitest run --config vitest.config.minimal.js",
    "test:watch": "vitest --config vitest.config.minimal.js",
    "test:ui": "vitest --ui --config vitest.config.minimal.js",
    "test:browser": "vitest --browser --config vitest.config.minimal.js",
    "test:coverage": "vitest run --coverage --config vitest.config.minimal.js",
    "test:coverage-ui": "vitest --ui --coverage --config vitest.config.minimal.js",
    "test:debug": "vitest --inspect-brk --pool=forks --config vitest.config.minimal.js",
    "test:reporter": "vitest run --reporter=verbose --reporter=json --outputFile=test-results.json --config vitest.config.minimal.js",
    "test:simple": "vitest run simple.test.js tests/working.test.js tests/basic.test.js --config vitest.config.minimal.js",
    "test:orm": "vitest run tests/simple-orm.test.js tests/orm-working.test.js --config vitest.config.minimal.js",
    "setup": "node scripts/setup-database.js",
    "setup:clean": "node scripts/setup-database.js --clean",
    "validate": "node scripts/validate-installation.js",
    "dev": "vitest",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "knex": "^3.1.0",
    "sqlite3": "^5.1.6",
    "objection": "^3.1.4"
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "@vitest/browser": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "vite": "^5.2.0",
    "c8": "^9.1.0",
    "playwright": "^1.43.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "vitest",
    "testing",
    "thermal",
    "monitoring",
    "database",
    "performance",
    "es-modules",
    "fast-testing"
  ],
  "author": "Thermal Testing Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/thermal-vitest-framework.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/thermal-vitest-framework/issues"
  },
  "homepage": "https://github.com/your-org/thermal-vitest-framework#readme",
  "volta": {
    "node": "20.12.0",
    "npm": "10.5.0"
  },
  "vitest": {
    "configFile": "./config/vitest.config.js"
  }
}
