{
  "name": "squirrel-framework",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "🐿️ Framework hybride moderne avec Vanilla JS + Tauri + Axum",  "scripts": {
    "dev": "./dev.sh",
    "build": "rollup -c --environment BUILD:production",
    "build:dev": "rollup -c --environment BUILD:development",
    "build:prod": "rollup -c --environment BUILD:production",
    "build:analyze": "rollup -c --environment BUILD:production,ANALYZE:true",
    "start:server": "node fastify-server.mjs",
    "start:websocket": "node src/server/server.js",
    "test:websocket": "npm run start:websocket",
    "serve": "python -m http.server 8000",
    "perf": "rollup -c --environment BUILD:development && python -m http.server 8000",    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@tauri-apps/cli": "^2.4.0",
    "babel-jest": "^30.0.0",
    "jest": "^30.0.0",
    "knex": "^3.1.0",
    "objection": "^3.1.5",
    "rollup": "^4.0.0",
    "rollup-plugin-filesize": "^10.0.0",
    "sqlite3": "^5.1.7"
  },  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "fastify": "^5.3.3",
    "fastify-socket.io": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "sequelize": "^6.37.3",
    "socket.io-client": "^4.7.5",
    "wavesurfer.js": "^7.9.5"
  }
}
